#!name=Meitu Premium

[MITM]
enable = true
hostname = h5.xiuxiu.meitu.com, api.xiuxiu.meitu.com

[Script]
meitu = type=http-response, pattern=^https?:\/\/(h5|api)\.xiuxiu\.meitu\.com\/v\d\/(h\d\/vip|vip|user)\/, script-path=https://raw.githubusercontent.com/ekaznyra/NguyenNgocAnhTu/main/Module/js/MeiTuXiuXiu.js, requires-body=true
